:: Story Stylesheet [stylesheet]
@import url('https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=Inter:wght@300;400&display=swap');

html, body {
  background: #0a0a0a;
  margin: 0;
  padding: 0;
  height: 100%;
  overflow: hidden;
}

#ui-bar { display: none; }
#ui-bar-toggle { display: none; }

#story {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  margin: 0;
  padding: 0;
}

.passage {
  max-width: 640px;
  padding: 2rem;
  font-family: 'EB Garamond', Georgia, serif;
  font-size: 1.35rem;
  line-height: 1.85;
  letter-spacing: 0.01em;
  color: #d4cfc4;
  animation: passageFadeIn 2s ease forwards;
  opacity: 0;
}

.passage p {
  margin-bottom: 1.2em;
}

.passage a {
  font-family: 'Inter', sans-serif;
  font-size: 0.8rem;
  font-weight: 300;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #5a5549;
  text-decoration: none;
  transition: color 0.6s ease;
}

.passage a:hover {
  color: #9a9080;
}

#ws-indicator {
  position: fixed;
  top: 2rem;
  left: 2rem;
  font-family: 'Inter', sans-serif;
  font-size: 0.65rem;
  font-weight: 300;
  letter-spacing: 0.1em;
  color: #2a2520;
}

#ws-indicator.connected { color: #3a4a3a; }

#passage-counter {
  position: fixed;
  top: 2rem;
  right: 2rem;
  font-family: 'Inter', sans-serif;
  font-size: 0.7rem;
  font-weight: 300;
  letter-spacing: 0.2em;
  color: #2a2520;
}

#progress-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  height: 2px;
  width: 0%;
  background: #3a3530;
  transition: width 0.5s linear;
}

@keyframes passageFadeIn {
  from {
    opacity: 0;
    transform: translateY(12px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.title-screen {
  text-align: center;
}

.title-screen .title {
  font-size: 1.6rem;
  margin-bottom: 0.5em;
}

.title-screen .subtitle {
  font-size: 0.95rem;
  color: #5a5549;
  margin-bottom: 2em;
}

.continue {
  display: inline-block;
  margin-top: 2rem;
}

:: Story JavaScript [script]
// ============================================================
// METAMORPHIC EFFORTS -- Engine code
// Text display + WebSocket data sender only.
// All audio is handled by TouchDesigner.
// ============================================================

window.ME = window.ME || {};
ME.wsUrl = 'ws://localhost:9980';
ME.ws = null;
ME.autoTimer = null;
ME.progressTimer = null;
ME.totalPassages = 10;

// -- WebSocket --
ME.connectWS = function() {
  try {
    ME.ws = new WebSocket(ME.wsUrl);
    ME.ws.onopen = function() {
      console.log('Connected to TouchDesigner');
      var el = document.getElementById('ws-indicator');
      if (el) { el.textContent = 'TD: connected'; el.className = 'connected'; }
    };
    ME.ws.onclose = function() {
      console.log('WebSocket closed. Reconnecting in 3s...');
      var el = document.getElementById('ws-indicator');
      if (el) { el.textContent = 'TD: disconnected'; el.className = ''; }
      setTimeout(ME.connectWS, 3000);
    };
    ME.ws.onerror = function() {
      var el = document.getElementById('ws-indicator');
      if (el) { el.textContent = 'TD: disconnected'; el.className = ''; }
    };
  } catch(e) {
    console.log('WebSocket not available');
  }
};

ME.sendBESS = function(data) {
  if (ME.ws && ME.ws.readyState === WebSocket.OPEN) {
    ME.ws.send(JSON.stringify(data));
    console.log('Sent to TD:', data);
  } else {
    console.log('TD not connected. Would send:', data);
  }
};

// -- Progress bar --
ME.startProgress = function(dwellMs) {
  var bar = document.getElementById('progress-bar');
  if (!bar) return;
  bar.style.width = '0%';
  var elapsed = 0;
  var step = 200;
  if (ME.progressTimer) clearInterval(ME.progressTimer);
  ME.progressTimer = setInterval(function() {
    elapsed += step;
    var pct = Math.min((elapsed / dwellMs) * 100, 100);
    bar.style.width = pct + '%';
    if (elapsed >= dwellMs) clearInterval(ME.progressTimer);
  }, step);
};

ME.stopProgress = function() {
  if (ME.progressTimer) clearInterval(ME.progressTimer);
  var bar = document.getElementById('progress-bar');
  if (bar) bar.style.width = '0%';
};

// -- Auto-advance --
ME.setAutoAdvance = function(targetPassage, dwellMs) {
  if (ME.autoTimer) clearTimeout(ME.autoTimer);
  ME.startProgress(dwellMs);
  ME.autoTimer = setTimeout(function() {
    Engine.play(targetPassage);
  }, dwellMs);
};

// -- Passage counter --
ME.setCounter = function(num) {
  var el = document.getElementById('passage-counter');
  if (el) {
    if (num === '') {
      el.textContent = '';
    } else {
      el.textContent = num + ' / ' + ME.totalPassages;
    }
  }
};

// -- Cleanup on every passage change --
$(document).on(':passageinit', function() {
  if (ME.autoTimer) clearTimeout(ME.autoTimer);
  ME.stopProgress();
});

// -- Initialize on load --
$(document).one(':storyready', function() {
  var body = document.body;

  var wsEl = document.createElement('div');
  wsEl.id = 'ws-indicator';
  wsEl.textContent = 'TD: disconnected';
  body.appendChild(wsEl);

  var counterEl = document.createElement('div');
  counterEl.id = 'passage-counter';
  body.appendChild(counterEl);

  var barEl = document.createElement('div');
  barEl.id = 'progress-bar';
  body.appendChild(barEl);

  ME.connectWS();
});

